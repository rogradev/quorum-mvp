generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                  String        @id @default(cuid())
  projectId           BigInt        @unique
  devWallet           String
  tokenMint           String        @unique
  projectPda          String        @unique
  name                String
  ticker              String
  description         String
  websiteUrl          String
  state               ProjectState  @default(SOCIAL_VOTING)

  // Fase 1 — Social (Día 1 al Día 30)
  socialVoteStart     DateTime
  socialVotes         BigInt        @default(0)

  // Fase 2 — Económica (abre Día 15, cierra Día 284)
  economicPhaseActive Boolean       @default(false)
  economicPhaseStart  DateTime?

  raiseGoal           BigInt
  totalRaised         BigInt        @default(0)
  holderCount         BigInt        @default(0)
  platformFeePaid     BigInt        @default(0)

  // Health checks trimestrales (informativos)
  healthCheck1Emitted Boolean       @default(false)
  healthCheck2Emitted Boolean       @default(false)

  // Vesting bilateral (Día 15 al Día 284)
  vestingStart        DateTime?
  vestingEnd          DateTime?

  // Inactividad del dev
  lastDevActivity     DateTime      @default(now())
  devLocked           Boolean       @default(false)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  contributions       Contribution[]
  socialVoteRecords   SocialVoteRecord[]

  @@map("projects")
}

enum ProjectState {
  SOCIAL_VOTING
  ECONOMIC_PHASE
  VESTING
  FAILED
  GRADUATED
}

model Contribution {
  id                String    @id @default(cuid())
  projectId         BigInt
  project           Project   @relation(fields: [projectId], references: [projectId])
  contributorWallet String
  contributionPda   String    @unique
  amountLamports    BigInt
  tokensAllocated   BigInt
  claimed           Boolean   @default(false)
  refunded          Boolean   @default(false)
  contributedAt     DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([projectId, contributorWallet])
  @@map("contributions")
}

model SocialVoteRecord {
  id          String    @id @default(cuid())
  projectId   BigInt
  project     Project   @relation(fields: [projectId], references: [projectId])
  voterWallet String
  votePda     String    @unique
  votedAt     DateTime  @default(now())

  @@unique([projectId, voterWallet])
  @@map("social_votes")
}

model PlatformStats {
  id                  String    @id @default("singleton")
  totalProjects       BigInt    @default(0)
  totalFeesCollected  BigInt    @default(0)
  lastSyncedAt        DateTime  @default(now())

  @@map("platform_stats")
}
