# ── Base de datos ─────────────────────────────────────────────
# PostgreSQL — Supabase (gratis): supabase.com
# o Neon (gratis): neon.tech
DATABASE_URL="postgresql://user:password@host:5432/quorum?sslmode=require"

# ── RPC de Solana ─────────────────────────────────────────────
# Opción A: Helius devnet (recomendado — gratis con API key)
# Crear cuenta en: helius.dev
NEXT_PUBLIC_RPC_ENDPOINT="https://devnet.helius-rpc.com/?api-key=TU_API_KEY"

# Opción B: RPC público de devnet (más lento, sin API key)
# NEXT_PUBLIC_RPC_ENDPOINT="https://api.devnet.solana.com"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
