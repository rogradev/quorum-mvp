            "name": "contributor",
            "docs": [
              "Wallet del contribuidor"
            ],
            "type": "pubkey"
          },
          {
            "name": "amount_lamports",
            "docs": [
              "Cantidad aportada en lamports"
            ],
            "type": "u64"
          },
          {
            "name": "tokens_allocated",
            "docs": [
              "Tokens asignados en proporción al aporte"
            ],
            "type": "u64"
          },
          {
            "name": "claimed",
            "docs": [
              "Si ya reclamó sus tokens post-vesting"
            ],
            "type": "bool"
          },
          {
